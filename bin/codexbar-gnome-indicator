#!/usr/bin/env python3
"""Small GNOME/AppIndicator wrapper for CodexBar CLI."""

from __future__ import annotations

import json
import os
import subprocess
import threading
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: E402
from gi.repository import Gdk, GLib, Gtk  # noqa: E402


APP_ID = "codexbar-gnome-indicator"
CODEXBAR = os.environ.get("CODEXBAR_BIN", str(Path.home() / ".local/bin/codexbar"))
PROVIDER = os.environ.get("CODEXBAR_INDICATOR_PROVIDER", "both")
SOURCE = os.environ.get("CODEXBAR_INDICATOR_SOURCE", "oauth")
REFRESH_SECONDS = int(os.environ.get("CODEXBAR_INDICATOR_REFRESH_SECONDS", "300"))
MAX_LIMIT_ROWS = 8
BAR_WIDTH = 10


def _run_codexbar() -> tuple[list[dict[str, Any]] | None, str | None, str]:
    cmd = [CODEXBAR, "usage", "--format", "json", "--no-color"]
    if PROVIDER:
        cmd.extend(["--provider", PROVIDER])
    if SOURCE:
        cmd.extend(["--source", SOURCE])
    try:
        proc = subprocess.run(cmd, text=True, capture_output=True, timeout=90, check=False)
    except Exception as exc:
        return None, f"{type(exc).__name__}: {exc}", ""

    output = proc.stdout.strip()
    if proc.returncode != 0 and not output:
        return None, (proc.stderr or f"codexbar exited with {proc.returncode}").strip(), ""

    try:
        payload = json.loads(output)
    except json.JSONDecodeError as exc:
        err = proc.stderr.strip() if proc.stderr else str(exc)
        return None, err, output

    if not isinstance(payload, list):
        return None, "Unexpected codexbar JSON shape", output
    return payload, None, output


def _window_percent(window: dict[str, Any] | None) -> int | None:
    if not isinstance(window, dict):
        return None
    value = window.get("usedPercent")
    if isinstance(value, (int, float)):
        return max(0, min(999, round(value)))
    return None


def _summarize_provider(item: dict[str, Any]) -> tuple[str, str, int | None, bool]:
    provider = str(item.get("provider") or "?")
    if isinstance(item.get("error"), dict):
        msg = str(item["error"].get("message") or "provider error")
        return provider, f"{provider}: ERROR: {msg}", None, True

    usage = item.get("usage") if isinstance(item.get("usage"), dict) else {}
    windows: list[tuple[str, int | None, str | None]] = [
        ("session", _window_percent(usage.get("primary")), _reset_text(usage.get("primary"))),
        ("weekly", _window_percent(usage.get("secondary")), _reset_text(usage.get("secondary"))),
        ("monthly", _window_percent(usage.get("tertiary")), _reset_text(usage.get("tertiary"))),
    ]
    for extra in usage.get("extraRateWindows") or []:
        if isinstance(extra, dict):
            title = str(extra.get("title") or extra.get("id") or "extra")
            window = extra.get("window") if isinstance(extra.get("window"), dict) else {}
            windows.append((title, _window_percent(window), _reset_text(window)))

    present = [(name, pct, reset) for name, pct, reset in windows if pct is not None]
    if not present:
        return provider, f"{provider}: no usage windows", None, False

    headline_name, headline_pct, _ = present[0]
    max_pct = max(pct for _, pct, _ in present if pct is not None)
    parts = [f"{name} {pct}%" + (f" reset {reset}" if reset else "") for name, pct, reset in present]
    account = usage.get("accountEmail") or usage.get("identity", {}).get("accountEmail")
    prefix = f"{provider}"
    if account:
        prefix += f" ({account})"
    return provider, f"{prefix}: {headline_name} {headline_pct}% | " + " | ".join(parts), max_pct, False


def _compact_summary(summary: str) -> str:
    head = summary.split(" | ", 1)[0]
    return head.replace(": ERROR:", " ERR:")


def _install_dark_menu_css() -> None:
    screen = Gdk.Screen.get_default()
    if screen is None:
        return
    provider = Gtk.CssProvider()
    provider.load_from_data(
        b"""
        menu {
          background: #151518;
          border: 1px solid #2a2a2e;
          border-radius: 14px;
          padding: 10px;
        }
        menuitem {
          color: #e8e4dc;
          background: transparent;
          border-radius: 8px;
          padding: 7px 12px;
          font-family: monospace;
          font-size: 12px;
        }
        menuitem:hover {
          background: #2a2a2e;
          color: #ffffff;
        }
        menuitem:disabled {
          color: #e8e4dc;
        }
        separator {
          background: #36363b;
          min-height: 1px;
          margin: 8px 0;
        }
        """
    )
    Gtk.StyleContext.add_provider_for_screen(
        screen,
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )


def _panel_label(payload: list[dict[str, Any]], has_error: bool) -> str:
    by_provider = {
        str(item.get("provider") or ""): item
        for item in payload
        if isinstance(item, dict)
    }

    def lane(provider: str, window_key: str) -> str:
        item = by_provider.get(provider) or {}
        usage = item.get("usage") if isinstance(item.get("usage"), dict) else {}
        percent = _window_percent(usage.get(window_key))
        return "--" if percent is None else f"{percent}%"

    label = "CxW {codex_weekly}  ClS {claude_session}  ClW {claude_weekly}".format(
        codex_weekly=lane("codex", "secondary"),
        claude_session=lane("claude", "primary"),
        claude_weekly=lane("claude", "secondary"),
    )
    return label + (" !" if has_error else "")


def _bar(percent: int | None) -> str:
    if percent is None:
        return "░" * BAR_WIDTH
    filled = max(0, min(BAR_WIDTH, round((percent / 100) * BAR_WIDTH)))
    if percent > 0 and filled == 0:
        filled = 1
    return "█" * filled + "░" * (BAR_WIDTH - filled)


def _short_reset(window: Any) -> str:
    if not isinstance(window, dict):
        return ""
    text = _reset_text(window)
    return f" · resets {text}" if text else ""


def _limit_row(label: str, percent: int | None, window: Any) -> dict[str, Any]:
    percent_text = "--" if percent is None else f"{percent}%"
    return {
        "label": label,
        "percent": percent,
        "text": f"{_bar(percent)}  {percent_text:>4}  {label}{_short_reset(window)}",
    }


def _collect_limit_rows(payload: list[dict[str, Any]]) -> list[dict[str, Any]]:
    by_provider = {
        str(item.get("provider") or ""): item
        for item in payload
        if isinstance(item, dict) and not isinstance(item.get("error"), dict)
    }
    rows: list[dict[str, Any]] = []

    codex = by_provider.get("codex") or {}
    codex_usage = codex.get("usage") if isinstance(codex.get("usage"), dict) else {}
    codex_week = codex_usage.get("secondary")
    if isinstance(codex_week, dict):
        rows.append(_limit_row("Codex Week", _window_percent(codex_week), codex_week))

    claude = by_provider.get("claude") or {}
    claude_usage = claude.get("usage") if isinstance(claude.get("usage"), dict) else {}
    claude_session = claude_usage.get("primary")
    if isinstance(claude_session, dict):
        rows.append(_limit_row("Claude Session", _window_percent(claude_session), claude_session))
    claude_week = claude_usage.get("secondary")
    if isinstance(claude_week, dict):
        rows.append(_limit_row("Claude Week", _window_percent(claude_week), claude_week))

    for item in payload:
        provider = str(item.get("provider") or "")
        usage = item.get("usage") if isinstance(item.get("usage"), dict) else {}
        for extra in usage.get("extraRateWindows") or []:
            if not isinstance(extra, dict):
                continue
            window = extra.get("window") if isinstance(extra.get("window"), dict) else {}
            percent = _window_percent(window)
            title = str(extra.get("title") or extra.get("id") or "extra")
            normalized = title.lower()
            if percent in (None, 0) and not any(token in normalized for token in ("fable", "opus", "sonnet")):
                continue
            display = title.replace(" only", "")
            if provider == "codex":
                display = f"Codex {display}"
            rows.append(_limit_row(display, percent, window))

    return rows[:MAX_LIMIT_ROWS]


def _reset_text(window: Any) -> str | None:
    if not isinstance(window, dict):
        return None
    text = window.get("resetDescription")
    if isinstance(text, str) and text:
        return text
    raw = window.get("resetsAt")
    if not isinstance(raw, str) or not raw:
        return None
    try:
        dt = datetime.fromisoformat(raw.replace("Z", "+00:00")).astimezone()
    except ValueError:
        return raw
    return dt.strftime("%b %d %H:%M")


class CodexBarIndicator:
    def __init__(self) -> None:
        self.indicator = AppIndicator.Indicator.new(
            APP_ID,
            "utilities-system-monitor",
            AppIndicator.IndicatorCategory.SYSTEM_SERVICES,
        )
        self.indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self.indicator.set_title("CodexBar")

        _install_dark_menu_css()
        self.menu = Gtk.Menu()
        self.limit_items: list[Gtk.MenuItem] = []
        for _ in range(MAX_LIMIT_ROWS):
            item = Gtk.MenuItem(label="")
            item.set_sensitive(False)
            item.hide()
            self.menu.append(item)
            self.limit_items.append(item)

        self.limit_separator = Gtk.SeparatorMenuItem()
        self.limit_separator.hide()
        self.menu.append(self.limit_separator)

        self.status_item = Gtk.MenuItem(label="CodexBar: starting...")
        self.status_item.set_sensitive(False)
        self.menu.append(self.status_item)

        self.details_item = Gtk.MenuItem(label="Show details")
        self.details_item.connect("activate", self.show_details)
        self.menu.append(self.details_item)

        self.refresh_item = Gtk.MenuItem(label="Refresh")
        self.refresh_item.connect("activate", self.refresh)
        self.menu.append(self.refresh_item)

        self.menu.append(Gtk.SeparatorMenuItem())
        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", lambda *_: Gtk.main_quit())
        self.menu.append(quit_item)
        self.menu.show_all()
        self.indicator.set_menu(self.menu)

        self.last_raw = ""
        self.last_summary = "CodexBar: starting..."
        self.refresh()
        GLib.timeout_add_seconds(REFRESH_SECONDS, self.refresh)

    def _set_limit_rows(self, rows: list[dict[str, Any]]) -> None:
        for item, row in zip(self.limit_items, rows):
            item.set_label(str(row["text"]))
            item.show()
        for item in self.limit_items[len(rows):]:
            item.hide()
        if rows:
            self.limit_separator.show()
            self.status_item.hide()
        else:
            self.limit_separator.hide()
            self.status_item.show()

    def refresh(self, *_: object) -> bool:
        if not self.last_raw:
            self.status_item.set_label("CodexBar: refreshing...")
        threading.Thread(target=self._refresh_worker, daemon=True).start()
        return True

    def _refresh_worker(self) -> None:
        payload, error, raw = _run_codexbar()
        GLib.idle_add(self._apply_refresh, payload, error, raw)

    def _apply_refresh(self, payload: list[dict[str, Any]] | None, error: str | None, raw: str) -> bool:
        if error:
            self.last_summary = f"CodexBar: ERROR: {error}"
            self.indicator.set_label("CB !", "CB 100%")
            self._set_limit_rows([])
            self.status_item.show()
            self.status_item.set_label(self.last_summary[:180])
            if raw:
                self.last_raw = raw
            return False

        assert payload is not None
        summaries: list[str] = []
        has_error = False
        for item in payload:
            _, summary, _, item_error = _summarize_provider(item)
            summaries.append(summary)
            has_error = has_error or item_error

        label = _panel_label(payload, has_error)
        limit_rows = _collect_limit_rows(payload)

        self.last_raw = raw
        self.last_summary = "\n".join(summaries) if summaries else "CodexBar: no providers returned"
        self.indicator.set_label(label, "CxW 100%  ClS 100%  ClW 100%")
        self._set_limit_rows(limit_rows)
        self.status_item.set_label("; ".join(_compact_summary(s) for s in summaries)[:180])
        return False

    def show_details(self, *_: object) -> None:
        text = self.last_summary
        if self.last_raw:
            text += "\n\nRaw JSON:\n" + self.last_raw
        subprocess.Popen(
            ["zenity", "--text-info", "--title", "CodexBar", "--width", "900", "--height", "650"],
            stdin=subprocess.PIPE,
            text=True,
        ).communicate(text)


def main() -> None:
    CodexBarIndicator()
    Gtk.main()


if __name__ == "__main__":
    main()
